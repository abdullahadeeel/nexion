#!/usr/bin/env php
<?php

require_once __DIR__ . '/vendor/autoload.php';

\Phpify\Exception\ErrorHandler::register();

// Load environment variables
\Phpify\Config\Dotenv::load(__DIR__);

/** @var \Phpify\Foundation\Application $app */
$app = require_once __DIR__ . '/bootstrap/app.php';

$kernel = $app->make(\Phpify\Console\Kernel::class);

$status = $kernel->handle(null);

exit($status);
