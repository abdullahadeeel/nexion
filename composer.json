{
  "name": "nexion/nexion",
  "description": "The Phpify Application Skeleton",
  "type": "project",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Nexion\\": "vendor/nexion/framework/src/",
      "Nexion\\Config\\": "vendor/nexion/config/src/",
      "Nexion\\Console\\": "vendor/nexion/console/src/",
      "Nexion\\Controller\\": "vendor/nexion/controller/src/",
      "Nexion\\Database\\": "vendor/nexion/database/src/",
      "Nexion\\Exception\\": "vendor/nexion/exception/src/",
      "Nexion\\Http\\": "vendor/nexion/http/src/",
      "Nexion\\Middleware\\": "vendor/nexion/middleware/src/",
      "Nexion\\Routing\\": "vendor/nexion/routing/src/",
      "Nexion\\View\\": "vendor/nexion/view/src/"
    }
  },
  "require": {
    "php": ">=8.0",
    "nexion/framework": "^1.0"
  },
  "minimum-stability": "stable"
}
