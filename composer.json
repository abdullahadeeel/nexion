{
    "name": "phpify/phpify",
    "description": "The Phpify Application Skeleton",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require": {
        "php": ">=8.0",
        "phpify/framework": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./phpify-packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev"
}
